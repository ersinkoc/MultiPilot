{
  "name": "multipilot-sidecar",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "npm run build:bundle && npm run build:binary",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.cjs --format=cjs --external:simple-git --external:chokidar --external:fs-extra --external:ws --external:express --external:cors",
    "build:binary": "node scripts/build-binary.js",
    "build:prod": "npm run build:bundle && pkg dist/index.cjs --targets node20-win-x64,node20-macos-x64,node20-linux-x64 --output dist/sidecar",
    "dev": "tsx src/index.ts",
    "test": "vitest"
  },
  "dependencies": {
    "simple-git": "^3.22.0",
    "chokidar": "^3.6.0",
    "fs-extra": "^11.2.0",
    "ws": "^8.16.0",
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "esbuild": "^0.20.0",
    "pkg": "^5.8.1",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/fs-extra": "^11.0.4",
    "@types/cors": "^2.8.17",
    "vitest": "^1.3.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^6.0.2"
  },
  "pkg": {
    "scripts": [
      "dist/index.cjs"
    ],
    "assets": [
      "node_modules/**/*"
    ],
    "targets": [
      "node20-win-x64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-linux-x64"
    ]
  }
}
